{
  "name": "agency-website",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:api": "turbo run dev --filter=api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter @agency/database db:generate",
    "db:migrate": "pnpm --filter @agency/database db:migrate",
    "db:push": "pnpm --filter @agency/database db:push",
    "db:seed": "pnpm --filter @agency/database db:seed",
    "db:studio": "pnpm --filter @agency/database db:studio",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0"
  }
}
