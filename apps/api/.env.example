NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agency_website?schema=public"
# Only needed when DATABASE_URL points through a pooler (e.g. Supabase PgBouncer) —
# migrations need a direct, non-pooled connection.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/agency_website?schema=public"

BETTER_AUTH_SECRET="replace-with-a-32-plus-character-random-secret"
BETTER_AUTH_URL="http://localhost:4000"
AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://localhost:3001"
AUTH_COOKIE_DOMAIN=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notifications for new contact form submissions. If left blank, the
# API logs a warning and skips sending instead of failing the submission.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Agency Website <no-reply@example.com>"
# Recipient for contact-form alerts. Falls back to the `contact_email` site
# setting (Settings page in the admin panel) if left blank.
ADMIN_NOTIFICATION_EMAIL=
