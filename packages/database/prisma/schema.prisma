// Agency Website — core schema.
// Conventions used throughout (see architecture plan):
//   - cuid ids, createdAt/updatedAt on every model
//   - ContentStatus + `order` Int on anything manageable/orderable from the admin panel
//   - slug (unique) on anything with its own public URL
//   - optional 1:1 SeoMeta relation on anything that renders its own page
//   - Media is the single source of truth for Cloudinary assets

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Shared enums
// ---------------------------------------------------------------------------

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TechCategory {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  DESIGN
  TOOL
}

enum FaqContext {
  GENERAL
  SERVICE
  PORTFOLIO
  CONTACT
  AFFILIATE
}

enum NavLocation {
  HEADER
  FOOTER
}

enum SubmissionStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  ARCHIVED
}

enum BillingType {
  ONE_TIME
  HOURLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PricingType {
  FIXED
  ONE_TIME
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  RETAINER
  CUSTOM
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  STRIPE
  PAYPAL
  WISE
  JAZZCASH
  EASYPAISA
  CUSTOM
}

// ---------------------------------------------------------------------------
// Auth (Better Auth — Prisma adapter shape) + RBAC
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Better Auth "admin" plugin baseline
  banned         Boolean   @default(false)
  banReason      String?
  banExpires     DateTime?

  // Granular RBAC extension
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  sessions Session[]
  accounts Account[]

  createdQuotations Quotation[]
  createdInvoices   Invoice[]
  createdPayments   Payment[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String
  label    String

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// Shared building blocks
// ---------------------------------------------------------------------------

model Media {
  id         String   @id @default(cuid())
  publicId   String   @unique
  url        String
  width      Int?
  height     Int?
  format     String?
  bytes      Int?
  altText    String?
  createdAt  DateTime @default(now())

  serviceHero      Service[]      @relation("ServiceHeroMedia")
  technologyLogo   Technology[]
  testimonialAvatar Testimonial[]
  teamMemberAvatar TeamMember[]
  affiliateToolLogo AffiliateTool[]
  ogImages         SeoMeta[]      @relation("SeoOgImage")
  twitterImages    SeoMeta[]      @relation("SeoTwitterImage")
  homeHeroBackgrounds HomePageContent[]
  paymentAttachments Payment[]
  pageSeoImages    PageSeo[]

  @@map("media")
}

// Generic SEO settings for pages that aren't backed by their own content
// model (Services/Portfolio/Affiliate Tools/Contact are static route
// components, unlike Home/About which have HomePageContent/AboutPageContent
// to hang a `seo` relation off of). `page` is a plain string key, not a
// Prisma enum, so a new page can be added purely at the application level
// (route + a new key) without a schema migration. One "social image" covers
// both Open Graph and Twitter Card, per product decision to keep the admin
// form simple -- the frontend derives both from it plus metaTitle/
// metaDescription rather than storing four separate fields.
model PageSeo {
  id              String   @id @default(cuid())
  page            String   @unique
  metaTitle       String
  metaDescription String
  keywords        String[] @default([])
  socialImageId   String?
  canonicalUrl    String?
  robots          String   @default("index, follow")
  updatedAt       DateTime @updatedAt

  socialImage Media? @relation(fields: [socialImageId], references: [id])

  @@map("page_seo")
}

model SeoMeta {
  id                 String   @id @default(cuid())
  metaTitle          String
  metaDescription    String
  keywords           String[]
  canonicalUrl       String?
  ogTitle            String?
  ogDescription      String?
  ogImageId          String?
  twitterCard        String   @default("summary_large_image")
  twitterTitle       String?
  twitterDescription String?
  twitterImageId     String?
  robots             String   @default("index, follow")
  structuredData     Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ogImage      Media? @relation("SeoOgImage", fields: [ogImageId], references: [id])
  twitterImage Media? @relation("SeoTwitterImage", fields: [twitterImageId], references: [id])

  service       Service?
  project       Project?
  homePage      HomePageContent?
  aboutPage     AboutPageContent?
  privacyPolicyPage PrivacyPolicyContent?
  termsPage         TermsContent?

  @@map("seo_meta")
}

model Technology {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  category  TechCategory
  logoId    String?
  order     Int          @default(0)
  isEnabled Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  logo     Media?    @relation(fields: [logoId], references: [id])
  services Service[] @relation("ServiceTechnologies")
  projects Project[] @relation("ProjectTechStack")

  @@map("technologies")
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String?
  company   String?
  avatarId  String?
  quote     String
  rating    Int      @default(5)
  status    ContentStatus @default(PUBLISHED)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  avatar   Media?    @relation(fields: [avatarId], references: [id])
  services Service[]
  projects Project[] @relation("ProjectTestimonials")

  @@map("testimonials")
}

model Faq {
  id        String     @id @default(cuid())
  question  String
  answer    String
  context   FaqContext @default(GENERAL)
  order     Int        @default(0)
  status    ContentStatus @default(PUBLISHED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  services Service[]

  @@map("faqs")
}

// ---------------------------------------------------------------------------
// Services
// ---------------------------------------------------------------------------

model ServiceCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  order     Int       @default(0)
  isEnabled Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  services  Service[]

  @@map("service_categories")
}

model Service {
  id          String        @id @default(cuid())
  categoryId  String?
  name        String
  slug        String        @unique
  tagline     String
  description String
  benefits    String[]
  process     Json // ordered [{ title, description }]
  deliverables String[]
  timeline    String
  heroMediaId String?
  status      ContentStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  order       Int           @default(0)
  seoId       String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category      ServiceCategory? @relation(fields: [categoryId], references: [id])
  heroMedia     Media?           @relation("ServiceHeroMedia", fields: [heroMediaId], references: [id])
  seo           SeoMeta?         @relation(fields: [seoId], references: [id])
  technologies  Technology[]     @relation("ServiceTechnologies")
  pricingPlans  PricingPlan[]
  faqs          Faq[]
  testimonials  Testimonial[]

  relatedFrom Service[] @relation("RelatedServices")
  relatedTo   Service[] @relation("RelatedServices")

  @@map("services")
}

model PricingPlan {
  id            String      @id @default(cuid())
  serviceId     String
  name          String // Starter | Professional | Business | Custom Quote
  regularPrice  Float? // required unless isCustomQuote (enforced in the route handler)
  discountPrice Float? // optional; must be less than regularPrice when present
  billingType   BillingType @default(ONE_TIME)
  priceLabel    String? // e.g. "Starting from"
  currency      String? // ISO 4217 code; null = use the site's global currency setting
  features      String[]
  isFeatured    Boolean  @default(false) // Custom Quote card
  isCustomQuote Boolean  @default(false)
  ctaLabel      String   @default("Get Started")
  ctaHref       String   @default("/contact")
  order         Int      @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("pricing_plans")
}

// ---------------------------------------------------------------------------
// Portfolio
// ---------------------------------------------------------------------------

model ProjectCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  order     Int       @default(0)
  isEnabled Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]

  @@map("project_categories")
}

model Project {
  id             String        @id @default(cuid())
  categoryId     String?
  title          String
  slug           String        @unique
  client         String?
  summary        String
  sections       Json     @default("[]") // ordered [{ id, title, content, icon, order }]
  results        Json // ordered [{ label, value }]
  liveUrl        String?
  githubUrl      String?
  videoUrl       String?
  videoPublicId  String?
  timelineStart  DateTime?
  timelineEnd    DateTime?
  status         ContentStatus @default(DRAFT)
  isFeatured     Boolean       @default(false)
  order          Int           @default(0)
  seoId          String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category     ProjectCategory? @relation(fields: [categoryId], references: [id])
  seo          SeoMeta?         @relation(fields: [seoId], references: [id])
  techStack    Technology[]     @relation("ProjectTechStack")
  gallery      ProjectImage[]
  testimonials Testimonial[]    @relation("ProjectTestimonials")

  relatedFrom Project[] @relation("RelatedProjects")
  relatedTo   Project[] @relation("RelatedProjects")

  quotations Quotation[]
  invoices   Invoice[]

  @@map("projects")
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  url       String
  publicId  String
  width     Int?
  height    Int?
  caption   String?
  order     Int     @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_images")
}

// ---------------------------------------------------------------------------
// About / Team
// ---------------------------------------------------------------------------

model TeamMember {
  id        String        @id @default(cuid())
  name      String
  role      String
  bio       String
  avatarId  String?
  socials   Json? // { twitter, linkedin, github, website }
  order     Int           @default(0)
  status    ContentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  avatar Media? @relation(fields: [avatarId], references: [id])
  skills Skill[]

  @@map("team_members")
}

model Skill {
  id          String  @id @default(cuid())
  name        String  @unique
  proficiency Int     @default(80) // 0-100
  order       Int     @default(0)
  isEnabled   Boolean @default(true)

  teamMembers TeamMember[]

  @@map("skills")
}

model CoreValue {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String // lucide icon name
  order       Int    @default(0)

  @@map("core_values")
}

model TimelineEvent {
  id          String   @id @default(cuid())
  year        String
  title       String
  description String
  order       Int      @default(0)

  @@map("timeline_events")
}

model Certification {
  id       String  @id @default(cuid())
  name     String
  issuer   String
  year     String
  url      String?
  order    Int     @default(0)

  @@map("certifications")
}

// ---------------------------------------------------------------------------
// Affiliate Tools
// ---------------------------------------------------------------------------

model AffiliateCategory {
  id        String          @id @default(cuid())
  slug      String          @unique
  name      String
  order     Int             @default(0)
  isEnabled Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt
  tools     AffiliateTool[]

  @@map("affiliate_categories")
}

model AffiliateTool {
  id             String        @id @default(cuid())
  categoryId     String
  name           String
  slug           String        @unique
  logoId         String?
  description    String
  benefits       String[]
  specialOffer   String?
  disclosureNote String?
  ctaLabel       String        @default("Visit Site")
  ctaUrl         String
  status         ContentStatus @default(PUBLISHED)
  isFeatured     Boolean       @default(false)
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category AffiliateCategory @relation(fields: [categoryId], references: [id])
  logo     Media?            @relation(fields: [logoId], references: [id])

  @@map("affiliate_tools")
}

// ---------------------------------------------------------------------------
// Contact / leads (seed of future CRM)
// ---------------------------------------------------------------------------

model ContactSubmission {
  id        String           @id @default(cuid())
  name      String
  email     String
  phone     String
  country   String
  city      String
  budget    String?
  message   String
  source    String? // which page/CTA
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("contact_submissions")
}

// ---------------------------------------------------------------------------
// Navigation / Footer / Settings
// ---------------------------------------------------------------------------

model NavItem {
  id       String      @id @default(cuid())
  label    String
  href     String
  location NavLocation
  parentId String?
  order    Int         @default(0)

  parent   NavItem?  @relation("NavItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children NavItem[] @relation("NavItemChildren")

  @@map("nav_items")
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("site_settings")
}

// ---------------------------------------------------------------------------
// Singleton page content (Home / About have bespoke, purposeful structure —
// not generic blocks)
// ---------------------------------------------------------------------------

model HomePageContent {
  id     String @id @default(cuid())

  // Hero
  heroBadgeText         String?
  heroHeadline          String
  heroSubheadline       String
  heroDescription       String?
  heroBackgroundImageId String?
  heroCtaLabel          String
  heroCtaHref           String
  heroCtaNewTab         Boolean @default(false)

  // Hero secondary CTA ("View our work")
  heroSecondaryCtaEnabled Boolean @default(true)
  heroSecondaryCtaLabel   String?
  heroSecondaryCtaHref    String?
  heroSecondaryCtaNewTab  Boolean @default(false)

  // Contact CTA (the single CTA block at the bottom of the home page)
  contactCtaHeading    String?
  contactCtaDescription String?
  contactCtaButtonText String?
  contactCtaButtonHref String?

  // Section headings/labels below the hero. Nullable so the existing row
  // keeps working untouched; the frontend falls back to the current copy
  // (via `??`) whenever one of these is null. May contain `**text**`
  // emphasis markers -- see Heading component in packages/ui.
  storyHeading          String?
  storyButtonLabel      String?
  storyMissionLabel     String?
  servicesHeading       String?
  servicesDescription   String?
  servicesButtonLabel   String?
  portfolioHeading      String?
  portfolioDescription  String?
  portfolioButtonLabel  String?
  processHeading        String?
  technologiesHeading   String?
  whyHeading             String?
  testimonialsHeading   String?

  seoId     String?  @unique
  updatedAt DateTime @updatedAt

  heroBackgroundImage Media?     @relation(fields: [heroBackgroundImageId], references: [id])
  seo                 SeoMeta?   @relation(fields: [seoId], references: [id])

  @@map("home_page_content")
}

// Lets a stat double as the single source of truth for a specific homepage
// callout (e.g. the About preview's "Years in business" figure) instead of
// that figure being entered a second time somewhere else. @unique so at most
// one stat can claim a given role.
enum HomeStatHighlight {
  YEARS_IN_BUSINESS
  PROJECTS_SHIPPED
}

model HomeStat {
  id           String             @id @default(cuid())
  number       String
  suffix       String?
  title        String
  description  String?
  order        Int                @default(0)
  isEnabled    Boolean            @default(true)
  highlightKey HomeStatHighlight? @unique

  @@map("home_stats")
}

model HomeProcessStep {
  id          String  @id @default(cuid())
  title       String
  description String
  order       Int     @default(0)
  isEnabled   Boolean @default(true)

  @@map("home_process_steps")
}

model HomeWhyReason {
  id          String  @id @default(cuid())
  icon        String
  title       String
  description String
  order       Int     @default(0)
  isEnabled   Boolean @default(true)

  @@map("home_why_reasons")
}

model AboutPageContent {
  id        String   @id @default(cuid())
  story     String
  mission   String
  vision    String
  philosophy String

  // Section headings/labels beyond the hero paragraph above. Nullable so the
  // existing row keeps working untouched; the frontend falls back to the
  // current copy (via `??`) whenever one of these is null. May contain
  // `**text**` emphasis markers -- see Heading component in packages/ui.
  heroHeading            String?
  missionLabel           String?
  visionLabel            String?
  philosophyLabel        String?
  valuesHeading          String?
  timelineHeading        String?
  teamHeading            String?
  skillsHeading          String?
  certificationsHeading  String?
  technologiesHeading    String?

  seoId     String?  @unique
  updatedAt DateTime @updatedAt

  seo SeoMeta? @relation(fields: [seoId], references: [id])

  @@map("about_page_content")
}

// ---------------------------------------------------------------------------
// Singleton page content for pages without their own bespoke model (Services/
// Portfolio/Affiliate Tools/Contact are otherwise static route components).
// Only a hero heading + paragraph -- the current layout has no separate
// "intro" section on any of these pages, so no unrendered fields are added.
// SEO for these pages stays on PageSeo, unchanged.
// ---------------------------------------------------------------------------

model ServicesPageContent {
  id              String   @id @default(cuid())
  heroHeading     String
  heroDescription String
  updatedAt       DateTime @updatedAt

  @@map("services_page_content")
}

model PortfolioPageContent {
  id              String   @id @default(cuid())
  heroHeading     String
  heroDescription String
  updatedAt       DateTime @updatedAt

  @@map("portfolio_page_content")
}

model AffiliateToolsPageContent {
  id              String   @id @default(cuid())
  heroHeading     String
  heroDescription String
  disclosureText  String
  updatedAt       DateTime @updatedAt

  @@map("affiliate_tools_page_content")
}

model ContactPageContent {
  id              String   @id @default(cuid())
  heroHeading     String
  heroDescription String
  whatsappLabel   String   @default("Chat on WhatsApp")
  calendlyLabel   String   @default("Book an intro call")
  updatedAt       DateTime @updatedAt

  @@map("contact_page_content")
}

// `content` only ever gets written by the publish action, so the public
// route always serves the last published snapshot even mid-edit. `draftContent`
// holds whatever was last "Save Draft"-ed and is null when there's nothing
// pending. `status` flips DRAFT -> PUBLISHED once and never reverts (no
// unpublish flow exists) -- the public route returns null unless PUBLISHED.
model PrivacyPolicyContent {
  id            String        @id @default(cuid())
  title         String        @default("Privacy Policy")
  content       String        @default("")
  draftContent  String?
  lastUpdatedAt DateTime?
  status        ContentStatus @default(DRAFT)
  publishedAt   DateTime?
  seoId         String?       @unique
  updatedAt     DateTime      @updatedAt

  seo SeoMeta? @relation(fields: [seoId], references: [id])

  @@map("privacy_policy_content")
}

model TermsContent {
  id            String        @id @default(cuid())
  title         String        @default("Terms & Conditions")
  content       String        @default("")
  draftContent  String?
  lastUpdatedAt DateTime?
  status        ContentStatus @default(DRAFT)
  publishedAt   DateTime?
  seoId         String?       @unique
  updatedAt     DateTime      @updatedAt

  seo SeoMeta? @relation(fields: [seoId], references: [id])

  @@map("terms_content")
}

// ---------------------------------------------------------------------------
// Finance
// ---------------------------------------------------------------------------

model Client {
  id         String   @id @default(cuid())
  name       String
  email      String?
  phone      String?
  company    String?
  address    String?
  currency   String
  notes      String?
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  quotations Quotation[]
  invoices   Invoice[]

  @@map("finance_clients")
}

model Quotation {
  id            String          @id @default(cuid())
  quoteNumber   String          @unique
  status        QuotationStatus @default(DRAFT)
  issueDate     DateTime
  expiryDate    DateTime
  clientId      String
  projectId     String?
  currency      String
  notes         String?
  terms         String?
  signatureText String?
  subtotal      Decimal         @default(0)
  discountTotal Decimal         @default(0)
  taxTotal      Decimal         @default(0)
  grandTotal    Decimal         @default(0)
  isArchived    Boolean         @default(false)
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  client    Client          @relation(fields: [clientId], references: [id])
  project   Project?        @relation(fields: [projectId], references: [id])
  createdBy User?           @relation(fields: [createdById], references: [id])
  items     QuotationItem[]
  invoices  Invoice[]

  @@map("finance_quotations")
}

model QuotationItem {
  id            String       @id @default(cuid())
  quotationId   String
  name          String
  description   String?
  pricingType   PricingType  @default(FIXED)
  quantity      Decimal      @default(1)
  unitPrice     Decimal
  discountType  DiscountType @default(PERCENT)
  discountValue Decimal      @default(0)
  taxPercent    Decimal      @default(0)
  lineTotal     Decimal      @default(0)
  order         Int          @default(0)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("finance_quotation_items")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime
  dueDate       DateTime
  clientId      String
  projectId     String?
  quotationId   String?
  currency      String
  notes         String?
  terms         String?
  signatureText String?
  subtotal      Decimal       @default(0)
  discountTotal Decimal       @default(0)
  taxTotal      Decimal       @default(0)
  grandTotal    Decimal       @default(0)
  amountPaid    Decimal       @default(0)
  balance       Decimal       @default(0)
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client    Client        @relation(fields: [clientId], references: [id])
  project   Project?      @relation(fields: [projectId], references: [id])
  quotation Quotation?    @relation(fields: [quotationId], references: [id])
  createdBy User?         @relation(fields: [createdById], references: [id])
  items     InvoiceItem[]
  payments  Payment[]

  @@map("finance_invoices")
}

model InvoiceItem {
  id            String       @id @default(cuid())
  invoiceId     String
  name          String
  description   String?
  pricingType   PricingType  @default(FIXED)
  quantity      Decimal      @default(1)
  unitPrice     Decimal
  discountType  DiscountType @default(PERCENT)
  discountValue Decimal      @default(0)
  taxPercent    Decimal      @default(0)
  lineTotal     Decimal      @default(0)
  order         Int          @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("finance_invoice_items")
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal
  currency      String
  paymentDate   DateTime
  method        PaymentMethod
  transactionId String?
  notes         String?
  attachmentId  String?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  attachment Media?  @relation(fields: [attachmentId], references: [id])
  createdBy  User?   @relation(fields: [createdById], references: [id])

  @@map("finance_payments")
}

model FinanceSettings {
  id                  String   @id @default(cuid())
  defaultCurrency     String   @default("PKR")
  supportedCurrencies String[]
  taxRate             Decimal  @default(0)
  invoicePrefix       String   @default("INV")
  quotePrefix         String   @default("QUO")
  invoiceNumberFormat String   @default("{PREFIX}-{YEAR}-{SEQ}")
  quoteNumberFormat   String   @default("{PREFIX}-{YEAR}-{SEQ}")
  nextInvoiceSeq      Int      @default(1)
  nextQuoteSeq        Int      @default(1)
  bankingDetails      Json?
  paymentInstructions String?
  footerNotes         String?
  termsAndConditions  String?
  updatedAt           DateTime @updatedAt

  @@map("finance_settings")
}
