DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agency_website?schema=public"

# Supabase (or any PgBouncer-fronted Postgres) needs a second, non-pooled
# connection string for migrations — PgBouncer's transaction mode doesn't
# support the prepared statements `prisma migrate`/`db push` rely on.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/agency_website?schema=public"
